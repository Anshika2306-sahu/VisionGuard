# Copy to .env and fill in. Never commit the real .env.

# --- GitHub ---
GITHUB_USERNAME=your_github_username
GITHUB_URL=https://github.com/your_github_username
GITHUB_TOKEN=__your_github_personal_access_token__

# --- Database ---
# Prototype default (Postgres in docker-compose). For an ultra-light local run, use sqlite:
# DATABASE_URL=sqlite:///./visionguard.db
DATABASE_URL=postgresql+psycopg://vg:vg@db:5432/visionguard

# --- Queue ---
REDIS_URL=redis://redis:6379/0

# --- Storage (evidence images) ---
STORAGE_BACKEND=local          # local | s3
STORAGE_DIR=./data/evidence

# --- MapMyIndia / Mappls (free dev tier) ---
# Get from https://developer.mappls.com -> create project -> keys
MAPPLS_REST_KEY=__your_rest_key__
MAPPLS_MAP_SDK_KEY=__your_map_sdk_key__

# --- Auth ---
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRE_MINUTES=720

# --- Models (paths relative to repo root) ---
MODEL_DETECTOR=ml/weights/uvh26/yolo11s.pt     # falls back to COCO yolo11n if missing
MODEL_HELMET=ml/weights/helmet/best.pt          # optional; heuristic stub if missing
MODEL_PLATE=ml/weights/plate/best.pt            # optional; uses detector 'plate' class if missing
OCR_ENGINE=easyocr                              # easyocr | paddleocr

# --- Inference thresholds ---
CONF_FLOOR=0.25
QUALITY_FLOOR=0.30

# --- CORS (frontend origin) ---
FRONTEND_ORIGIN=http://localhost:5173
