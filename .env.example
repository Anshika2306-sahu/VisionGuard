# ============================================================================
# VisionGuard — environment template.
# Copy to .env and replace every __PLACEHOLDER__ with a real value.
# NEVER commit the real .env (it is gitignored).
# After deploying, ROTATE any token that was shared, then paste the fresh one here.
# ============================================================================

# --- GitHub (for pushing the repo) -----------------------------------------
GITHUB_USERNAME=__your_github_username__
GITHUB_TOKEN=__your_github_personal_access_token__

# --- Hugging Face (model download + Spaces deploy) -------------------------
# Create at https://huggingface.co/settings/tokens  (needs 'write' for deploy)
HUGGINGFACE_TOKEN=__your_hf_token__

# --- MapMyIndia / Mappls (free dev tier) ----------------------------------
# Create at https://developer.mappls.com -> project -> keys
MAPPLS_REST_KEY=__your_mappls_rest_key__
MAPPLS_MAP_SDK_KEY=__your_mappls_map_sdk_key__

# --- Roboflow (helmet/plate dataset) --------------------------------------
ROBOFLOW_WORKSPACE=__your_roboflow_workspace__
ROBOFLOW_API_KEY=__your_roboflow_api_key__

# --- Vercel (optional: frontend hosting) ----------------------------------
VERCEL_TOKEN=__your_vercel_token__

# --- Database --------------------------------------------------------------
# Local: SQLite (no creds). Docker/scale: Postgres.
DATABASE_URL=sqlite:///./data/visionguard.db
# DATABASE_URL=postgresql+psycopg://vg:vg@db:5432/visionguard

# --- Queue / processing ----------------------------------------------------
REDIS_URL=redis://redis:6379/0
PROCESS_MODE=inline                 # inline | celery

# --- Storage (evidence images) ---------------------------------------------
STORAGE_BACKEND=local               # local | s3
STORAGE_DIR=./data/evidence

# --- Auth ------------------------------------------------------------------
JWT_SECRET=__a_long_random_string__
JWT_EXPIRE_MINUTES=720

# --- Models (paths relative to repo root) ----------------------------------
MODEL_DETECTOR=ml/weights/uvh26/yolo11s.pt   # falls back to COCO if missing
MODEL_HELMET=ml/weights/helmet/best.pt        # optional; heuristic stub if missing
OCR_ENGINE=easyocr                            # easyocr | paddleocr

# --- Inference thresholds --------------------------------------------------
CONF_FLOOR=0.25
QUALITY_FLOOR=0.30

# --- Frontend --------------------------------------------------------------
FRONTEND_ORIGIN=http://localhost:5173
# For a hosted frontend pointing at a remote backend:
# VITE_API_BASE=https://<your-space>.hf.space/api/v1
